# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# TinyMCE API Key (optional, for rich text editor)
VITE_TINYMCE_API_KEY=your-tinymce-api-key-here

# Tempo Development Tools (optional)
VITE_TEMPO=false

# Environment
NODE_ENV=development

# --- Variables pour le Pipeline d'Articles IA ---
GEMINI_API_KEY=your-gemini-api-key-here
VITE_SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
CRON_SECRET=your-vercel-cron-secret-here
